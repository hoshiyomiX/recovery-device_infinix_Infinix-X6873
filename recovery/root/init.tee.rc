# Infinix X6873 - Trustonic TEE Init Configuration
# FIXED: Proper TEE initialization without premature RPMB access
#
# This file is imported by init.recovery.mt6897.rc
# Service definitions are in init.recovery.mt6897.rc for proper ordering

on init
    # Create mountpoints for vendor partitions
    mkdir /mnt/vendor/persist 0771 system system
    mkdir /mnt/vendor/nvdata 0771 system system
    mkdir /mnt/vendor/nvcfg 0771 system system
    mkdir /mnt/vendor/protect_f 0771 system system
    mkdir /mnt/vendor/protect_s 0771 system system
    
    # ========================================
    # FIX: Create TEE directories (not accessing RPMB yet)
    # ========================================
    mkdir /mnt/vendor/persist/tee 0770 system system
    mkdir /mnt/vendor/persist/tlbin 0770 system system
    mkdir /mnt/vendor/persist/sp_cryptography 0770 system system

on post-fs
    # ========================================
    # FIX: Create directories but DO NOT access RPMB yet
    # RPMB access requires TEE to be fully initialized
    # ========================================
    
    # Create mcRegistry to store failure record
    mkdir /mnt/vendor/persist/mcRegistry 0771 system system
    mkdir /mnt/vendor/persist/rpmb 0700 system system
    mkdir /mnt/vendor/persist/startPara 0700 system system
    
    # Create backup directory (backup happens later via rpmb_backup_service)
    mkdir /mnt/vendor/persist/rpmb_backup 0700 system system
    
    # ========================================
    # REMOVED: Premature RPMB backup
    # OLD CODE: exec -- /vendor/bin/sh -c "cp -r /mnt/vendor/persist/rpmb/* /mnt/vendor/persist/rpmb_backup/ 2>/dev/null || true"
    # This was causing issues because RPMB was accessed before TEE initialization
    # RPMB backup is now handled by rpmb_backup_service after TEE is ready
    # ========================================

on post-fs-data
    # Create /data/vendor/key_provisioning dir and get proper encryption policy installed
    mkdir /data/vendor/key_provisioning 0771 system system
    
    # ========================================
    # FIX: Create additional data directories for TEE
    # ========================================
    mkdir /data/vendor/tee 0770 system system
    mkdir /data/vendor/keymaster 0770 system system
    mkdir /data/vendor/gatekeeper 0770 system system
    mkdir /data/vendor/mcRegistry 0775 system system

# ========================================
# TEE State for META/FACTORY mode
# ========================================
on property:ro.crypto.state=unsupported
    write /proc/bootprof "MOBICORE: create /data/vendor/mcRegistry ++ (unencrypted)"
    mkdir /data/vendor/mcRegistry 0775 system system
    write /proc/bootprof "MOBICORE: create /data/vendor/mcRegistry -- (unencrypted)"

# ========================================
# Normal mode, FBE
# ========================================
on property:ro.crypto.type=file && property:ro.crypto.state=encrypted
    write /proc/bootprof "MOBICORE: create /data/vendor/mcRegistry ++ (FBE encrypted)"
    mkdir /data/vendor/mcRegistry 0775 system system
    write /proc/bootprof "MOBICORE: create /data/vendor/mcRegistry -- (FBE encrypted)"

# ========================================
# Normal mode, FDE
# ========================================
on property:vold.decrypt=trigger_restart_framework
    write /proc/bootprof "MOBICORE: create /data/vendor/mcRegistry ++ (FDE encrypted)"
    mkdir /data/vendor/mcRegistry 0775 system system
    write /proc/bootprof "MOBICORE: create /data/vendor/mcRegistry -- (FDE encrypted)"

# ========================================
# FIX: Handle mobicore state changes
# ========================================
on property:init.svc.mobicore=running
    # Mobicore started successfully - signal TEE ready
    setprop ro.vendor.mobicore.ready true

on property:init.svc.mobicore=stopped
    # Mobicore stopped - clear ready flag
    setprop ro.vendor.mobicore.ready false
    setprop ro.vendor.trustonic.ready false
