<?xml version="1.0" encoding="utf-8"?>
<!--
    VINTF Manifest for Infinix X6873 Recovery
    Platform: MT6897 (Dimensity 8350 Ultimate)
    TEE: Trustonic Kinibi with Keymint 3.0
-->
<manifest version="4.0" type="device" target-level="6">
    <!-- AIDL Keymint 3.0 -->
    <hal format="aidl">
        <name>android.hardware.security.keymint</name>
        <version>3</version>
        <fqname>IKeyMintDevice/default</fqname>
    </hal>
    <hal format="aidl">
        <name>android.hardware.security.keymint</name>
        <version>3</version>
        <fqname>IRemotelyProvisionedComponent/default</fqname>
    </hal>

    <!-- AIDL Gatekeeper V1 -->
    <hal format="aidl">
        <name>android.hardware.gatekeeper</name>
        <version>1</version>
        <fqname>IGatekeeper/default</fqname>
    </hal>

    <!-- HIDL Keymaster 4.1 (for compatibility) -->
    <hal format="hidl">
        <name>android.hardware.keymaster</name>
        <transport>hwbinder</transport>
        <version>4.1</version>
        <interface>
            <name>IKeymasterDevice</name>
            <instance>default</instance>
        </interface>
        <fqname>@4.1::IKeymasterDevice/default</fqname>
    </hal>

    <!-- Trustonic TEE -->
    <hal format="hidl">
        <name>vendor.trustonic.tee</name>
        <transport>hwbinder</transport>
        <version>1.1</version>
        <interface>
            <name>ITee</name>
            <instance>default</instance>
        </interface>
        <fqname>@1.1::ITee/default</fqname>
    </hal>

    <!-- Trustonic TUI -->
    <hal format="hidl">
        <name>vendor.trustonic.tee.tui</name>
        <transport>hwbinder</transport>
        <version>1.0</version>
        <interface>
            <name>ITui</name>
            <instance>default</instance>
        </interface>
        <fqname>@1.0::ITui/default</fqname>
    </hal>

    <!-- Boot Control -->
    <hal format="aidl">
        <name>android.hardware.boot</name>
        <version>1</version>
        <fqname>IBootControl/default</fqname>
    </hal>

    <!-- Health HAL -->
    <hal format="aidl">
        <name>android.hardware.health</name>
        <version>1</version>
        <fqname>IHealth/default</fqname>
    </hal>

    <sepolicy>
        <version>35.0</version>
    </sepolicy>
    <kernel target-level="6"/>
</manifest>
