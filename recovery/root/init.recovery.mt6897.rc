# ============================================================
# Infinix X6873 Recovery Init Configuration
# Based on firmware dump analysis for proper decryption flow
# Reference: https://source.android.com/docs/core/architecture/android/init
# ============================================================

import /init.tee.rc
import /init.recovery.usb.rc

on init
    export LD_LIBRARY_PATH /system/lib64:/vendor/lib64:/vendor/lib64/hw
    
    # USB controller setup
    setprop sys.usb.controller 112b0000.dwc3
    setprop sys.usb.configfs 1
    
    # Crypto properties from firmware vendor/build.prop
    setprop ro.hardware.kmsetkey trustonic
    setprop ro.hardware.gatekeeper trustonic
    setprop ro.vendor.mtk_trustonic_tee_support 1
    setprop ro.crypto.volume.filenames_mode aes-256-cts

on fs
    install_keyring
    wait /dev/block/platform/soc/112b0000.ufshci
    symlink /dev/block/platform/soc/112b0000.ufshci /dev/block/bootdevice

# We need vold early for metadata encryption
on early-fs
    start vold

on late-fs
    # Mount RW partitions which need run fsck
    mount_all /first_stage_ramdisk/fstab.mt6897 --late

on post-fs
    start boot-hal-1-2

    symlink /dev/block/mapper/pl_a /dev/block/by-name/preloader_raw_a
    symlink /dev/block/mapper/pl_b /dev/block/by-name/preloader_raw_b

    # Create directories for Transsion security services (from firmware tee.rc)
    mkdir /mnt/vendor/persist 0771 system system
    mkdir /mnt/vendor/persist/mcRegistry 0771 system system
    mkdir /mnt/vendor/persist/keybox 0771 system system
    mkdir /mnt/vendor/persist/startPara 0777 system system
    mkdir /mnt/vendor/persist/rpmb 0700 system system
    mkdir /mnt/vendor/persist/paytrigger 0777 system system
    mkdir /tranfs 0771 system system
    mkdir /tranfs/rpmb 0700 system system
    mkdir /tranfs/startPara 0700 system system
    
    # Set ownership for persist
    chown system system /mnt/vendor/persist
    chmod 0771 /mnt/vendor/persist
    restorecon /mnt/vendor/persist

on boot
    start mtk.plpath.utils.link
    start vendor.usb_hal
    start vendor.usb_gadget_hal
    start vendor.vibrator_hal
    
    # Enable ADB - this triggers adbd start via property trigger in init.recovery.usb.rc
    setprop sys.usb.config adb

on property:persist.vendor.mtk.pl_lnk=1
    symlink /dev/block/mapper/pl_a /dev/block/by-name/preloader_raw_a
    symlink /dev/block/mapper/pl_b /dev/block/by-name/preloader_raw_b
    symlink /dev/block/mapper/pl_a /dev/block/platform/bootdevice/by-name/preloader_raw_a
    symlink /dev/block/mapper/pl_b /dev/block/platform/bootdevice/by-name/preloader_raw_b

# FSTAB_RAW2(lk2,bootloader2) of fstab.in.emmc
    symlink /dev/block/by-name/lk1 /dev/block/by-name/bootloader1
    symlink /dev/block/by-name/lk2 /dev/block/by-name/bootloader2

# Fix ro.vendor.mtk_ufs_support remove issue of recovery mode
on property:vendor.mtk.boot0_linka=1
    symlink /dev/block/sda /dev/block/mmcblk0boot0

on property:vendor.mtk.boot0_linkb=1
    symlink /dev/block/sdb /dev/block/mmcblk0boot0

on property:vendor.mtk.boot0_linkc=1
    symlink /dev/block/sdc /dev/block/mmcblk0boot0

on property:vendor.mtk.boot1_linka=1
    symlink /dev/block/sda /dev/block/mmcblk0boot1

on property:vendor.mtk.boot1_linkb=1
    symlink /dev/block/sdb /dev/block/mmcblk0boot1

on property:vendor.mtk.boot1_linkc=1
    symlink /dev/block/sdc /dev/block/mmcblk0boot1

service mtk.plpath.utils.link /system/bin/mtk_plpath_utils
    class main
    user root
    group root system
    oneshot
    disabled
    seclabel u:r:recovery:s0

# ============================================================
# DECRYPTION SERVICE STARTUP SEQUENCE
# Based on firmware init files analysis
# Reference: vendor/etc/init/*.rc from firmware dump
# ============================================================

# Trustonic TEE Service - provides TEE communication layer
# Reference: vendor/etc/init/vendor.trustonic.tee@1.1-service.rc
service tee-1-1 /vendor/bin/hw/vendor.trustonic.tee@1.1-service
    class hal
    user system
    group system
    disabled
    seclabel u:r:recovery:s0

# Gatekeeper Service - Trustonic version
# Reference: vendor/etc/init/android.hardware.gatekeeper-service.trustonic.rc
# Note: Firmware uses service name "vendor.gatekeeper-default"
service vendor.gatekeeper-default /vendor/bin/hw/android.hardware.gatekeeper-service.trustonic
    class early_hal
    user system
    group system
    disabled
    seclabel u:r:recovery:s0

# Keymint Service - Trustonic version
# Reference: vendor/etc/init/android.hardware.security.keymint@3.0-service.trustonic.rc
service vendor.keymint-trustonic /vendor/bin/hw/android.hardware.security.keymint@3.0-service.trustonic
    class early_hal
    interface android.hardware.keymaster@4.0::IKeymasterDevice default
    interface android.hardware.keymaster@4.1::IKeymasterDevice default
    interface android.hardware.security.keymint.IKeyMintDevice/default
    interface android.hardware.security.keymint.IRemotelyProvisionedComponent/default
    interface android.hardware.security.sharedsecret.ISharedSecret/default
    interface android.hardware.security.secureclock.ISecureClock/default
    user system
    group system
    disabled
    seclabel u:r:recovery:s0

# Transsion RPMB Service - required for secure storage
# Reference: vendor/etc/init/vendor.transsion.hardware.security.rpmbservice@1.0-service.rc
service rpmbservice /vendor/bin/hw/vendor.transsion.hardware.security.rpmbservice@1.0-service
    class hal
    user system
    group system
    disabled
    seclabel u:r:recovery:s0

# Transsion Device Authentication Service
# Reference: vendor/etc/init/vendor.transsion.hardware.security.deviceauthen@2.0-service.rc
service deviceauthen_hal_service /vendor/bin/hw/vendor.transsion.hardware.security.deviceauthen@2.0-service
    class hal
    user system
    group system
    disabled
    seclabel u:r:recovery:s0

# Transsion HAP Service
service vendor.hap_hal /vendor/bin/hw/vendor.transsion.hardware.security.hap@1.0-service
    class late_start
    user system
    group system
    disabled
    seclabel u:r:recovery:s0

# Transsion Critical Parameter Verification Service
service trancriticalparavfy_service /vendor/bin/hw/vendor.transsion.hardware.security.trancriticalparavfy@1.0-service
    class hal
    user system
    group system
    disabled
    seclabel u:r:recovery:s0

# Trustonic Keybox Check Service
service trustonic_check_keybox_service /vendor/bin/kmsetkey_ca.trustonic -c
    class late_start
    user system
    group system
    oneshot
    disabled
    seclabel u:r:recovery:s0

# ============================================================
# SERVICE STARTUP TRIGGERS - PROPER DEPENDENCY CHAIN
# Reference: Android Init Language - Property Triggers
# https://android.googlesource.com/platform/system/core/+/master/init/README.md
# ============================================================

# Phase 1: Start mobicore (mcDriverDaemon) when hwservicemanager is ready
# Note: mobicore service is defined in init.tee.rc
on property:hwservicemanager.ready=true
    start mobicore

# Phase 2: Start TEE service after mobicore daemon is running
on property:init.svc.mobicore=running
    start tee-1-1

# Phase 3: Start security HALs after TEE is ready
on property:init.svc.tee-1-1=running
    setprop ro.vendor.trustonic.ready true
    start vendor.keymint-trustonic
    start rpmbservice
    start deviceauthen_hal_service

# Phase 4: Start gatekeeper after TEE ready (from firmware gatekeeper rc)
on property:ro.vendor.trustonic.ready=true
    start vendor.gatekeeper-default

# Phase 5: Start additional services after keymint is running
on property:init.svc.vendor.keymint-trustonic=running
    start trancriticalparavfy_service
    start vendor.hap_hal

# ============================================================
# CLEANUP TRIGGERS
# ============================================================

on property:twrp.decrypt.done=true
    stop mobicore
    stop vendor.gatekeeper-default
    stop vendor.keymint-trustonic
    stop tee-1-1
    stop rpmbservice
    stop deviceauthen_hal_service

on post-fs-data
    mkdir /data/vendor_de 0770 system system
    mkdir /data/vendor_de/0 0770 system system
    mkdir /data/vendor_de/0/cryptoeng 0770 system system
    mkdir /data/vendor/key_provisioning 0771 system system
    mkdir /data/vendor/mcRegistry 0775 system system

    start health-hal-2-1

# USB HAL Service for OTG support
service vendor.usb_hal /vendor/bin/hw/android.hardware.usb-aidl-service.mediatekv1.0
    class hal
    user system
    group system
    disabled
    seclabel u:r:recovery:s0

# USB Gadget HAL Service
service vendor.usb_gadget_hal /vendor/bin/hw/android.hardware.usb.gadget-aidl-service.mediatekv1.0
    class hal
    user system
    group system mtp shell
    disabled
    seclabel u:r:recovery:s0

# Vibrator HAL Service
service vendor.vibrator_hal /vendor/bin/hw/android.hardware.vibrator-service.mediatek
    class hal
    user system
    group system
    setenv RICHTAP_DEVICE_PATH /dev/aw8697_haptic
    setenv ENV_RICHTAP_CONFIG_PATH /vendor/etc/aac_richtap.config
    disabled
    seclabel u:r:recovery:s0
